// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash            String                  // Bcrypt hashed password
  fullName               String?
  companyName            String?
  role                   String                  // BUYER or SELLER (required, no default)
  categoriesServed       String?                 // JSON array of categories for SELLER users
  serviceArea            String?                 // Service area (zip codes, city, radius) for SELLER users
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  rfqs                   RFQ[]
  bids                   Bid[]
  notifications          Notification[]
  orders                 Order[]
  preferredSupplierRules PreferredSupplierRule[]
  agentThreads           AgentThread[]
}

model RFQ {
  id                String         @id @default(cuid())
  rfqNumber         String
  status            String         @default("OPEN")
  createdAt         DateTime       @default(now())
  title             String
  notes             String         @default("")
  category          String
  categoryId        String?
  buyerId           String
  buyer             User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  jobNameOrPo       String?
  visibility        String?
  targetSupplierIds String? // JSON array
  lineItems         String // JSON array
  terms             String // JSON object
  awardedBidId      String?
  awardedAt         DateTime?
  bids              Bid[]
  messages          Message[]
  notifications     Notification[]
}

model Bid {
  id             String    @id @default(cuid())
  rfqId          String
  rfq            RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  status         String    @default("SUBMITTED") // SUBMITTED, WON, LOST
  lineItems      String // JSON array
  notes          String    @default("")
  deliveryCharge Float?
  total          Float?
  leadTimeDays   Int?
  seenByBuyerAt  DateTime?
  seenBySellerAt DateTime?
}

model Message {
  id             String    @id @default(cuid())
  rfqId          String
  rfq            RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  threadId       String // Format: thread:rq={rfqId}|b={buyerId}|s={sellerId}
  buyerId        String?
  sellerId       String?
  fromRole       String // BUYER or SELLER
  fromName       String?
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  metadata       String? // JSON object
  seenByBuyerAt  DateTime?
  seenBySellerAt DateTime?
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rfqId     String?
  rfq       RFQ?      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  type      String // BID_RECEIVED, RFQ_SENT, MESSAGE_RECEIVED, etc.
  createdAt DateTime  @default(now())
  readAt    DateTime?
  data      String? // JSON object
}

model Order {
  id                   String   @id @default(cuid())
  buyerId              String
  buyer                User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  rfqId                String
  bidId                String?
  status               String   @default("pending") // pending, confirmed, scheduled, delivered, cancelled
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lineItems            String // JSON array
  subtotal             Float
  taxes                Float
  total                Float
  fulfillmentType      String // PICKUP or DELIVERY
  requestedDate        String
  deliveryPreference   String? // MORNING or ANYTIME
  deliveryInstructions String?
  location             String?
  notes                String?
}

model PreferredSupplierRule {
  id        String   @id @default(cuid())
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  category  String   // Legacy field (kept for backward compatibility)
  categoryId String?  // Canonical categoryId (preferred)
  sellerIds String   // JSON array
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([buyerId, categoryId])
  @@index([buyerId, categoryId])
}

model AgentThread {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String?
  // JSON strings (match existing pattern in your schema)
  messages    String   @default("[]")  // JSON array
  draft       String   @default("{}")  // JSON object
  meta        String?                  // JSON object (optional)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model EmailEvent {
  id                String   @id @default(cuid())
  to                String
  subject           String
  status            String   // SENT | FAILED | OUTBOX
  providerMessageId String?
  error             String?
  rfqId             String?
  supplierId        String?
  createdAt         DateTime @default(now())

  @@index([rfqId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash            String                  // Bcrypt hashed password
  fullName               String?
  companyName            String?
  role                   String                  // BUYER or SELLER (required, no default)
  categoriesServed       String?                 // JSON array of categories for SELLER users
  serviceArea            String?                 // Service area (zip codes, city, radius) for SELLER users
  createdAt              DateTime                @default(now())
