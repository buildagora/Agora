{
  "name": "agora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=prisma/schema.prisma",
    "db:migrate:dev": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=prisma/schema.prisma",
    "db:status": "npx prisma migrate status --schema=prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "postinstall": "npm run db:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "setup:db": "bash scripts/setup-local-db.sh",
    "dev": "npx tsx scripts/assert-cwd.ts && node scripts/check-root.js && npx tsx scripts/assert-project-root.ts && next dev --turbo --hostname 127.0.0.1 --port 3000",
    "dev:clean": "npx tsx scripts/assert-cwd.ts && rm -rf .next && node scripts/check-root.js && npx tsx scripts/assert-project-root.ts && next dev --turbo --hostname 127.0.0.1 --port 3000",
    "dev:webpack": "npx tsx scripts/assert-cwd.ts && node scripts/check-root.js && npx tsx scripts/assert-project-root.ts && next dev",
    "dev:status": "npx tsx scripts/dev-status.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:messages": "tsx scripts/test-messages.ts",
    "test:requests": "tsx scripts/test-requests.ts",
    "test:recommendation": "tsx scripts/test-recommendation.ts",
    "test:orders": "tsx scripts/test-orders.ts",
    "test:exceptions": "tsx scripts/test-exceptions.ts",
    "test:agent-contract": "tsx scripts/test-agent-contract.ts",
    "test:intent-router": "tsx scripts/test-intent-router.ts",
    "test:slot-filler": "tsx scripts/test-slot-filler.ts",
    "test:orchestrator": "tsx scripts/test-orchestrator.ts",
    "test:agent-ui": "tsx scripts/test-agent-ui-contract.ts",
    "test:agent-handshake": "tsx scripts/test-agent-handshake.ts",
    "test:create-rfq": "tsx scripts/test-create-rfq-contract.ts",
    "test:rfqs-delete": "tsx scripts/test-rfqs-delete.ts",
    "test:dashboard-rfq-source": "tsx scripts/test-dashboard-rfq-source.ts",
    "test:auth": "tsx scripts/test-auth-smoke.ts",
    "test:rfq-email": "node -r dotenv/config node_modules/.bin/tsx scripts/test-rfq-email-smoke.ts dotenv_config_path=.env.local",
    "test:bid-notify": "node -r dotenv/config node_modules/.bin/tsx scripts/test-bid-notify-smoke.ts dotenv_config_path=.env.local",
    "test:bid-flow": "node -r dotenv/config node_modules/.bin/tsx scripts/test-bid-notify-smoke.ts dotenv_config_path=.env.local",
    "test:award-flow": "node -r dotenv/config node_modules/.bin/tsx scripts/test-award-flow-smoke.ts dotenv_config_path=.env.local",
    "rfq:doctor": "tsx scripts/rfq-doctor.ts",
    "foundation:check": "bash scripts/foundation-check.sh",
    "guard:legacy": "bash scripts/forbid-legacy-foundation.sh",
    "smoke": "node scripts/smoke.mjs",
    "db:migrate:apply": "node scripts/apply-migration.js",
    "dev:reset": "NODE_ENV=development npx tsx scripts/dev-hard-reset.ts",
    "purge:dev": "NODE_ENV=development npx tsx scripts/dev-hard-reset.ts",
    "dev:reset:check": "node -p \"require('./package.json').scripts['dev:reset']\"",
    "assert-db-empty": "npx tsx scripts/assert-db-empty.ts",
    "prisma:clean": "rm -rf node_modules/.prisma node_modules/@prisma && rm -rf .next",
    "prisma:reinstall": "npm install && npm run db:generate",
    "backfill:seller-orgs": "node -r dotenv/config node_modules/.bin/tsx scripts/backfill-seller-orgs.ts dotenv_config_path=.env.local",
    "backfill:supplier-categories": "node -r dotenv/config node_modules/.bin/tsx scripts/backfill-supplier-categories.ts dotenv_config_path=.env.local",
    "pretest": "npm run guard:legacy",
    "prebuild": "npm run guard:legacy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "next": "16.1.1",
    "openai": "^6.16.0",
    "pg": "^8.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.6.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.14",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jest": "^30.2.0",
    "playwright": "^1.58.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
